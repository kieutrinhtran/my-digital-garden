{# 
  Component: Article Tags and Actions
  Description: Hiển thị tags, like và share buttons
#}
{% set articleLikes = page | get_likes %}
<div class="article-tags-section">
  {% if tags %}
  <div class="article-tags">
    <span class="article-tags-label">Tags:</span>
    {% for tag in tags %}
      {% if tag != 'gardenEntry' and tag != 'note' %}
        <a href="/tags/{{ tag | slugify }}/" class="article-tag">{{ tag }}</a>
      {% endif %}
    {% endfor %}
  </div>
  {% endif %}
  <div class="article-actions">
    <button class="article-like-btn">
      <i icon-name="thumbs-up"></i>
      <span>Thích ({{ articleLikes }})</span>
    </button>
    <div class="article-share">
      <span class="article-share-label">Chia sẻ bài viết này:</span>
      <button class="article-share-icon js-share-btn" title="Chia sẻ">
        <i icon-name="share-2"></i>
      </button>
      <button class="article-share-icon js-copy-link-btn" title="Sao chép liên kết">
        <i icon-name="at-sign"></i>
      </button>
    </div>
  </div>
</div>

