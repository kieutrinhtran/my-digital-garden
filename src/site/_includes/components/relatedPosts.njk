{# 
  Component: Related Posts
  Description: Hiển thị các bài viết liên quan
#}
{% if relatedPosts and relatedPosts.length > 0 %}
<div class="article-related-posts">
    <h3 class="article-related-title">
        <span class="article-related-title-bar">|</span>
        Bài viết liên quan
    </h3>
    <div class="article-related-grid">
        {% for post in relatedPosts | slice(0, 3) %}
        <a href="{{ post.url }}" class="article-related-card">
            <div class="article-related-image">
              {% if post.data.image or post.data.thumbnail %}
                <img src="{{ post.data.image or post.data.thumbnail }}" alt="{{ post.title }}" loading="lazy">
              {% else %}
                <div class="article-related-image-placeholder">
                  <i icon-name="file-text"></i>
                </div>
              {% endif %}
              <div class="article-related-category">{{ post | get_category | upper }}</div>
            </div>
            <div class="article-related-content">
                <h4 class="article-related-card-title">{{ post.title }}</h4>
                <div class="article-related-meta">
                  {% if post.date %}
                    <time datetime="{{ post.date | dateToZulu }}">{{ post.date | date('%d Th%m') }}</time>
                  {% endif %}
                  {% if post.templateContent %}
                    {% set readingTime = post.templateContent | get_reading_time %}
                    {% if readingTime and readingTime > 0 %}
                    <span>• {{ readingTime }} phút đọc</span>
                    {% endif %}
                  {% endif %}
                </div>
            </div>
        </a>
        {% endfor %}
    </div>
</div>
{% endif %}

