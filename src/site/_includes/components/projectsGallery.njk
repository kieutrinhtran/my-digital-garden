{# 
  Component: Projects Gallery
  Description: Hiển thị portfolio projects với filters theo technology/tool cho Data Analyst
#}
<div class="projects-gallery-section" x-data="projectsGallery">
  <div class="projects-gallery-header">
    <h2 class="projects-gallery-title">
      <i icon-name="database"></i>
      Data Analysis Projects
    </h2>
    <p class="projects-gallery-subtitle">Khám phá các dự án phân tích dữ liệu và insights</p>
  </div>

  {# Filter Buttons #}
  <div class="projects-filters">
    <button 
      class="filter-btn" 
      :class="{ 'active': activeFilter === 'all' }"
      @click="activeFilter = 'all'">
      <i icon-name="grid-3x3"></i>
      All Projects
    </button>
    <button 
      class="filter-btn" 
      :class="{ 'active': activeFilter === 'sql' }"
      @click="activeFilter = 'sql'">
      <i icon-name="database"></i>
      SQL
    </button>
    <button 
      class="filter-btn" 
      :class="{ 'active': activeFilter === 'python' }"
      @click="activeFilter = 'python'">
      <i icon-name="code"></i>
      Python
    </button>
    <button 
      class="filter-btn" 
      :class="{ 'active': activeFilter === 'visualization' }"
      @click="activeFilter = 'visualization'">
      <i icon-name="bar-chart-3"></i>
      Visualization
    </button>
    <button 
      class="filter-btn" 
      :class="{ 'active': activeFilter === 'dashboard' }"
      @click="activeFilter = 'dashboard'">
      <i icon-name="layout-dashboard"></i>
      Dashboard
    </button>
    <button 
      class="filter-btn" 
      :class="{ 'active': activeFilter === 'statistics' }"
      @click="activeFilter = 'statistics'">
      <i icon-name="trending-up"></i>
      Statistics
    </button>
  </div>

  {# Projects Grid #}
  {% set allProjects = collections.projects %}
  <div class="projects-grid">
    {% for project in allProjects %}
      {% set projectTech = [] %}
      {% if project.data.technology %}
        {% if project.data.technology is iterable and project.data.technology is not string %}
          {% set projectTech = project.data.technology | map("lower") | list %}
        {% else %}
          {% set projectTech = [project.data.technology | lower] %}
        {% endif %}
      {% endif %}
      {% if project.data.tool %}
        {% if project.data.tool is iterable and project.data.tool is not string %}
          {% set toolTech = project.data.tool | map("lower") | list %}
          {% set projectTech = projectTech | concat(toolTech) %}
        {% else %}
          {% set projectTech = projectTech | concat([project.data.tool | lower]) %}
        {% endif %}
      {% endif %}
      {% set projectTags = (project.data.tags || []) | map("lower") | list %}
      {% set allTech = projectTech | concat(projectTags) %}
      
      <article 
        class="project-card"
        x-show="activeFilter === 'all' || 
                {% for tech in allTech %}'{{ tech }}'.includes(activeFilter) || {% endfor %}false">
        <a href="{{ project.url }}" class="project-card-link">
          <div class="project-card-image">
            {% if project.data.image or project.data.thumbnail %}
              <img src="{{ project.data.image or project.data.thumbnail }}" alt="{{ project.data.title or project.fileSlug }}" loading="lazy">
            {% else %}
              <div class="project-card-image-placeholder">
                <i icon-name="database"></i>
              </div>
            {% endif %}
            <div class="project-card-overlay">
              <div class="project-card-tech">
                {% if project.data.technology or project.data.tool %}
                  {% set tech = project.data.technology or project.data.tool %}
                  {% if tech is iterable and tech is not string %}
                    {% for t in tech | slice(0, 3) %}
                      <span class="tech-badge">{{ t }}</span>
                    {% endfor %}
                  {% else %}
                    <span class="tech-badge">{{ tech }}</span>
                  {% endif %}
                {% endif %}
              </div>
            </div>
          </div>
          
          <div class="project-card-content">
            <div class="project-card-header">
              {% if project.data.category %}
                <span class="project-category">{{ project.data.category }}</span>
              {% endif %}
              {% if project.date %}
                <span class="project-date">{{ project.date | time_ago }}</span>
              {% endif %}
            </div>
            
            <h3 class="project-card-title">{{ project.data.title or project.fileSlug }}</h3>
            
            {% if project.templateContent %}
              {% set excerpt = project.templateContent | striptags | truncate(120) %}
              {% if excerpt %}
                <p class="project-card-description">{{ excerpt }}</p>
              {% endif %}
            {% endif %}
            
            <div class="project-card-footer">
              <div class="project-card-stats">
                <span class="project-stat">
                  <i icon-name="eye"></i>
                  <span>{{ project | get_views(graph) | format_views }}</span>
                </span>
                {% if project.templateContent %}
                  {% set readingTime = project.templateContent | get_reading_time %}
                  {% if readingTime and readingTime > 0 %}
                  <span class="project-stat">
                    <i icon-name="clock"></i>
                    <span>{{ readingTime }} min</span>
                  </span>
                  {% endif %}
                {% endif %}
              </div>
              <div class="project-card-action">
                <i icon-name="arrow-right"></i>
              </div>
            </div>
          </div>
        </a>
      </article>
    {% endfor %}
  </div>

  {# Empty State #}
  <div x-show="activeFilter !== 'all' && getVisibleProjectsCount() === 0" 
       x-cloak
       class="projects-empty-state">
    <i icon-name="search-x"></i>
    <h3>Không tìm thấy project nào</h3>
    <p>Thử chọn filter khác hoặc xem tất cả projects.</p>
  </div>
</div>
