<script>
  (function () {
    const root = document.documentElement;
    const savedTheme = localStorage.getItem("dg-theme");
    if (savedTheme === "light" || savedTheme === "dark") {
      root.setAttribute("data-theme", savedTheme);
    }

    function getCurrentTheme() {
      return root.getAttribute("data-theme") || "dark";
    }

    function setTheme(theme) {
      root.setAttribute("data-theme", theme);
      localStorage.setItem("dg-theme", theme);
      document.querySelectorAll("[data-theme-toggle] i").forEach((icon) => {
        icon.setAttribute("icon-name", theme === "dark" ? "sun" : "moon");
      });
      if (window.lucide) window.lucide.createIcons();
    }

    document.addEventListener("DOMContentLoaded", function () {
      setTheme(getCurrentTheme());

      document.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
        btn.addEventListener("click", function () {
          const next = getCurrentTheme() === "dark" ? "light" : "dark";
          setTheme(next);
        });
      });

      // Reading progress
      const progress = document.querySelector(".reading-progress-bar");
      if (progress) {
        const updateProgress = () => {
          const scrollTop = window.scrollY;
          const height = document.documentElement.scrollHeight - window.innerHeight;
          const percent = height > 0 ? Math.min(100, Math.max(0, (scrollTop / height) * 100)) : 0;
          progress.style.width = percent + "%";
        };
        window.addEventListener("scroll", updateProgress, { passive: true });
        updateProgress();
      }

      // Share + copy link
      const sharePayload = { title: document.title, url: window.location.href };
      document.querySelectorAll(".js-share-btn").forEach((btn) => {
        btn.addEventListener("click", async function () {
          if (navigator.share) {
            await navigator.share(sharePayload);
          } else if (navigator.clipboard) {
            await navigator.clipboard.writeText(window.location.href);
          }
        });
      });
      document.querySelectorAll(".js-copy-link-btn").forEach((btn) => {
        btn.addEventListener("click", async function () {
          if (navigator.clipboard) {
            await navigator.clipboard.writeText(window.location.href);
          }
        });
      });

      // Search shortcut "/"
      document.addEventListener("keydown", function (e) {
        const target = e.target;
        const typingField = target && (target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.isContentEditable);
        if (typingField) return;
        if (e.key === "/" && typeof window.toggleSearch === "function") {
          e.preventDefault();
          window.toggleSearch();
          const term = document.getElementById("term");
          if (term) term.focus();
        }
      });

      // Basic image lightbox
      document.querySelectorAll(".cm-s-obsidian img, .article-featured-image img, .project-featured-image img").forEach((img) => {
        img.style.cursor = "zoom-in";
        img.addEventListener("click", function () {
          const overlay = document.createElement("div");
          overlay.className = "dg-lightbox";
          overlay.innerHTML = '<img src="' + img.src + '" alt="' + (img.alt || "") + '" />';
          overlay.addEventListener("click", () => overlay.remove());
          document.body.appendChild(overlay);
        });
      });

      // TOC scroll spy
      const tocLinks = Array.from(document.querySelectorAll(".toc-left-content a[href^='#']"));
      const headings = tocLinks
        .map((link) => document.getElementById(link.getAttribute("href").slice(1)))
        .filter(Boolean);
      if (tocLinks.length && headings.length) {
        const onScroll = () => {
          let current = null;
          for (const heading of headings) {
            if (heading.getBoundingClientRect().top <= 120) current = heading.id;
          }
          tocLinks.forEach((link) => {
            link.classList.toggle("is-active", link.getAttribute("href") === "#" + current);
          });
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }
    });
  })();
</script>
