{# 
  Component: Mini Charts for Data Analyst Homepage
  Description: Mini charts và stats visualization cho Data Analyst portfolio
#}
<div class="mini-charts-section">
  {# Stats Mini Chart #}
  <div class="mini-chart-card">
    <div class="mini-chart-header">
      <h3 class="mini-chart-title">Content Statistics</h3>
      <span class="mini-chart-period">Last 30 days</span>
    </div>
    <div class="mini-chart-content">
      {% set totalPosts = collections.published | length %}
      {% set totalProjects = collections.projects | length %}
      {% set recentPosts = collections.published | rejectattr("date", "olderThan", 30) | length %}
      
      <div class="mini-chart-bars">
        <div class="mini-chart-bar" style="height: {{ (totalPosts / (totalPosts + totalProjects) * 100) | round }}%">
          <span class="bar-value">{{ totalPosts }}</span>
          <span class="bar-label">Articles</span>
        </div>
        <div class="mini-chart-bar" style="height: {{ (totalProjects / (totalPosts + totalProjects) * 100) | round }}%">
          <span class="bar-value">{{ totalProjects }}</span>
          <span class="bar-label">Projects</span>
        </div>
        <div class="mini-chart-bar" style="height: {{ (recentPosts / totalPosts * 100) | round }}%">
          <span class="bar-value">{{ recentPosts }}</span>
          <span class="bar-label">Recent</span>
        </div>
      </div>
    </div>
  </div>

  {# Technology Distribution #}
  <div class="mini-chart-card">
    <div class="mini-chart-header">
      <h3 class="mini-chart-title">Tech Stack Distribution</h3>
    </div>
    <div class="mini-chart-content">
      {% set projectsByTech = collections.projectsByTech %}
      {% set totalTechProjects = 0 %}
      {% for tech, projects in projectsByTech %}
        {% set totalTechProjects = totalTechProjects + (projects | length) %}
      {% endfor %}
      
      <div class="mini-chart-donut">
        {% set techCount = 0 %}
        {% for tech, projects in projectsByTech %}
          {% if projects | length > 0 %}
            {% set techCount = techCount + 1 %}
            {% set percentage = (projects | length / totalTechProjects * 100) | round %}
            <div class="donut-segment" 
                 style="--percentage: {{ percentage }}%; --index: {{ techCount }};"
                 title="{{ tech }}: {{ projects | length }} projects">
              <span class="segment-label">{{ tech | replace("-", " ") | title }}</span>
              <span class="segment-value">{{ percentage }}%</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  {# Activity Timeline #}
  <div class="mini-chart-card">
    <div class="mini-chart-header">
      <h3 class="mini-chart-title">Activity Timeline</h3>
      <span class="mini-chart-period">Last 12 months</span>
    </div>
    <div class="mini-chart-content">
      <div class="mini-chart-timeline">
        {% set postsByMonth = {} %}
        {% for post in collections.published %}
          {% if post.date %}
            {% set monthKey = post.date | date('%Y-%m') %}
            {% if not postsByMonth[monthKey] %}
              {% set postsByMonth = postsByMonth | merge({monthKey: 0}) %}
            {% endif %}
            {% set postsByMonth = postsByMonth | merge({monthKey: postsByMonth[monthKey] + 1}) %}
          {% endif %}
        {% endfor %}
        
        {% for month, count in postsByMonth %}
          <div class="timeline-bar" style="height: {{ (count * 20) | round }}px" title="{{ month }}: {{ count }} posts">
            <span class="timeline-value">{{ count }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  .mini-charts-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .mini-chart-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .mini-chart-card:hover {
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .mini-chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .mini-chart-title {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
  }

  .mini-chart-period {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .mini-chart-content {
    min-height: 120px;
  }

  /* Bar Chart */
  .mini-chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 1rem;
    height: 120px;
    padding: 0.5rem 0;
  }

  .mini-chart-bar {
    flex: 1;
    background: linear-gradient(180deg, rgba(135, 206, 235, 0.6), rgba(111, 74, 255, 0.6));
    border-radius: 8px 8px 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0.5rem;
    min-height: 40px;
    position: relative;
    transition: all 0.3s ease;
  }

  .mini-chart-bar:hover {
    transform: scaleY(1.05);
    background: linear-gradient(180deg, rgba(135, 206, 235, 0.8), rgba(111, 74, 255, 0.8));
  }

  .mini-chart-bar .bar-value {
    font-size: 1.125rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: 0.25rem;
  }

  .mini-chart-bar .bar-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.7);
  }

  /* Donut Chart */
  .mini-chart-donut {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .donut-segment {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.75rem;
    background: rgba(135, 206, 235, 0.1);
    border: 1px solid rgba(135, 206, 235, 0.2);
    border-radius: 8px;
    min-width: 80px;
    transition: all 0.3s ease;
  }

  .donut-segment:hover {
    background: rgba(135, 206, 235, 0.2);
    border-color: rgba(135, 206, 235, 0.4);
    transform: scale(1.05);
  }

  .donut-segment .segment-label {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 0.25rem;
    text-align: center;
  }

  .donut-segment .segment-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-accent-primary);
  }

  /* Timeline Chart */
  .mini-chart-timeline {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    height: 120px;
    padding: 0.5rem 0;
  }

  .timeline-bar {
    flex: 1;
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.6), rgba(37, 99, 235, 0.6));
    border-radius: 4px 4px 0 0;
    min-height: 20px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 0.25rem;
    position: relative;
    transition: all 0.3s ease;
  }

  .timeline-bar:hover {
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.8), rgba(37, 99, 235, 0.8));
    transform: scaleY(1.1);
  }

  .timeline-bar .timeline-value {
    font-size: 0.6875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 768px) {
    .mini-charts-section {
      grid-template-columns: 1fr;
    }
  }
</style>
