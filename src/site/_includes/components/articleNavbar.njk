{# 
  Component: Article Navbar
  Description: Navbar cho trang article với BlogSpace style
#}
<nav class="article-navbar">
  <div class="article-navbar-container">
    <div class="article-navbar-left">
      <a href="/" class="article-navbar-logo">
        <span>BlogSpace</span>
      </a>
      <div class="article-navbar-menu">
        <a href="/" class="article-nav-link">Trang chủ</a>
        <a href="/posts/" class="article-nav-link">Danh mục</a>
        <a href="#" class="article-nav-link">Phổ biến</a>
        <a href="#" class="article-nav-link">Tác giả</a>
      </div>
    </div>
    <div class="article-navbar-center">
      <div class="article-search-bar">
        <i icon-name="search"></i>
        <input type="text" placeholder="Tìm kiếm bài viết..." />
      </div>
    </div>
    <div class="article-navbar-right">
      <button class="article-write-btn">
        <i icon-name="pen-tool"></i>
        <span>Viết bài</span>
      </button>
      <div class="article-user-avatar">
        <i icon-name="user"></i>
      </div>
    </div>
  </div>
</nav>

