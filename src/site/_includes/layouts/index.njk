<!DOCTYPE html>
<html lang="{{ meta.mainLanguage }}">
  <head>
    <title>{% if title %}{{ title }}{% else %}{{ page.fileSlug }}{% endif %}</title>
    {%include "components/pageheader.njk"%}
    {% for imp in dynamics.common.head %}
      {% include imp %}
    {% endfor %}
    {% for imp in dynamics.index.head %}
      {% include imp %}
    {% endfor %}
  </head>
  <body class="theme-{{meta.baseTheme}} markdown-preview-view markdown-rendered markdown-preview-section {{meta.bodyClasses}} {% if page.url == '/' %}blogos-dashboard-page{% endif %} {% if page.url == '/posts/' %}posts-route-page{% endif %}">
    <div class="reading-progress-track"><div class="reading-progress-bar"></div></div>
    {%include "components/notegrowthhistory.njk"%}
    
    {# Hide default navbar and sidebar for dashboard homepage and posts page #}
    {% if page.url != "/" and page.url != "/posts/" %}
      {# Always show navbar #}
      {%include "components/navbar.njk"%}

      {% if settings.dgEnableSearch === true %}
        {%include "components/searchContainer.njk"%}
      {% endif %}

      {# TOC Left Sidebar #}
      {% include "components/tocLeft.njk" %}
    {% endif %}

    <main class="content cm-s-obsidian {{contentClasses}}">
      {# Homepage: Skip header, show content directly #}
      {% if page.url == "/" %}
        <article class="content-body">
          {% if content %}
            {{ content | hideDataview | taggify | link | safe}}
          {% endif %}
        </article>
      {% else %}
        {# Other pages: Show header #}
        <header class="content-header">
          {% if settings.dgShowInlineTitle === true %}
            <h1 data-note-icon="{% if noteIcon %}{{noteIcon}}{% else %}{{meta.noteIconsSettings.default}}{% endif %}">
              {% if title %}{{ title }}{% else %}{{ page.fileSlug }}{% endif %}
            </h1>
          {% endif %}

          <div class="header-meta">
            {% if settings.dgShowTags === true and tags %}
              <div class="header-tags">
                {% for tag in tags %}
                  {% if tag != 'gardenEntry' and tag !='note' %}
                    <a class="tag" onclick="toggleTagSearch(this)">
                      #{{tag}}
                    </a>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
            
            {%- if meta.timestampSettings.showCreated or meta.timestampSettings.showUpdated -%}
              <div class="timestamps">
                {%- if meta.timestampSettings.showCreated and created -%}
                  <div class="timestamp-item">
                    <i icon-name="calendar-plus"></i>
                    <span class="human-date" data-date="{{created}}"></span>
                  </div>
                {%- endif -%}
                {%- if meta.timestampSettings.showUpdated and updated -%}
                  <div class="timestamp-item">
                    <i icon-name="calendar-clock"></i>
                    <span class="human-date" data-date="{{updated}}"></span>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
          
          {% for imp in dynamics.common.header %}
            {% include imp %}
          {% endfor %}
          {% for imp in dynamics.index.header %}
            {% include imp %}
          {% endfor %}
        </header>
        
        {% for imp in dynamics.common.beforeContent %}
          {% include imp %}
        {% endfor %}
        {% for imp in dynamics.index.beforeContent %}
          {% include imp %}
        {% endfor %}
        
        <article class="content-body">
          {% if content %}
            {{ content | hideDataview | taggify | link | safe}}
          {% endif %}
        </article>
      {% endif %}
      
      {# Posts Gallery - Hide for dashboard homepage and posts page #}
      {% if page.url != "/" and page.url != "/posts/" %}
        {% include "components/postsGallery.njk" %}
        
        {# Post Heatmap #}
        {% include "components/postHeatmap.njk" %}
      {% endif %}
      
      {% for imp in dynamics.common.afterContent %}
        {% include imp %}
      {% endfor %}
      {% for imp in dynamics.index.afterContent %}
        {% include imp %}
      {% endfor %}
    </main>

    {# Hide default sidebar for dashboard homepage and posts page #}
    {% if page.url != "/" and page.url != "/posts/" %}
      {%include "components/sidebar.njk"%}
    {% endif %}

    {% if page.url != "/" and page.url != "/posts/" %}
      {% if settings.dgLinkPreview === true %}
        {%include "components/linkPreview.njk"%}
      {% endif %}
      {% include "components/references.njk" %}
      {% include "components/timestamps.njk" %}
    {% endif %}
    
    {% for imp in dynamics.common.footer %}
      {% include imp %}
    {% endfor %}
    {% for imp in dynamics.index.footer %}
      {% include imp %}
    {% endfor %}
    
    <script>
        lucide.createIcons({
            attrs: {
                class: ["svg-icon"]
            }
        });
    </script>
    {% if page.url != "/" and page.url != "/posts/" %}
      {%include "components/backToTop.njk"%}
      {%include "components/codeBlockCopy.njk"%}
      {%include "components/uxEnhancements.njk"%}
    {% endif %}
  </body>
</html>
